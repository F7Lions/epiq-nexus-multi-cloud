    <script>pipeline {
    agent any
    
    // Define the inputs we need at runtime
    parameters {
        string(name: &apos;COMMIT_SHA&apos;, description: &apos;The exact GitHub Commit SHA from UAT&apos;)
        password(name: &apos;AWS_ACCESS_KEY&apos;, description: &apos;Temporary AWS Access Key for the Auditor&apos;)
        password(name: &apos;AWS_SECRET_KEY&apos;, description: &apos;Temporary AWS Secret Key for the Auditor&apos;)
    }
    
    // Inject parameters as environment variables for the AWS CLI
    environment {
        AWS_ACCESS_KEY_ID = &quot;${params.AWS_ACCESS_KEY}&quot;
        AWS_SECRET_ACCESS_KEY = &quot;${params.AWS_SECRET_KEY}&quot;
        AWS_REGION = &quot;ap-southeast-1&quot;
        AWS_ACCOUNT_ID = &quot;425629232565&quot; // Your AWS Account ID
        ECR_REPO = &quot;epiq-discovery-engine&quot;
    }

    stages {
        stage(&apos;IM8 Gate: AWS ECR Authentication&apos;) {
            steps {
                sh &apos;&apos;&apos;
                echo &quot;Authenticating Compliance Auditor with AWS Vault...&quot;
                aws ecr get-login-password --region $AWS_REGION | docker login --username AWS --password-stdin $AWS_ACCOUNT_ID.dkr.ecr.$AWS_REGION.amazonaws.com
                &apos;&apos;&apos;
            }
        }
        
        stage(&apos;IM8 Gate: Verify Cryptographic Hash&apos;) {
            steps {
                sh &apos;&apos;&apos;
                echo &quot;Pulling exact commit artifact: $COMMIT_SHA&quot;
                docker pull $AWS_ACCOUNT_ID.dkr.ecr.$AWS_REGION.amazonaws.com/$ECR_REPO:$COMMIT_SHA
                &apos;&apos;&apos;
            }
        }
        
        stage(&apos;IM8 Gate: Trivy Vulnerability Scan&apos;) {
            steps {
                // We run Aquasec Trivy in a sibling container to scan the image
                // We set exit-code 1 to FAIL the build if HIGH or CRITICAL vulnerabilities are found
                sh &apos;&apos;&apos;
                echo &quot;Scanning artifact for IM8 compliance...&quot;
                docker run --rm -v /var/run/docker.sock:/var/run/docker.sock aquasec/trivy image \
                  --severity HIGH,CRITICAL \
                  --exit-code 1 \
                  $AWS_ACCOUNT_ID.dkr.ecr.$AWS_REGION.amazonaws.com/$ECR_REPO:$COMMIT_SHA
                &apos;&apos;&apos;
            }
        }
        
        stage(&apos;IM8 Gate: Artifact Sign-Off&apos;) {
            steps {
                echo &quot;✅ Image SHA:$COMMIT_SHA has passed all IM8 compliance checks.&quot;
                echo &quot;✅ Cryptographic hash verified. No Critical/High vulnerabilities found.&quot;
                echo &quot;🚀 Artifact is officially SIGNED and ready for Azure PROD deployment.&quot;
            }
        }
    }
}</script>
